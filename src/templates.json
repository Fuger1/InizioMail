      { "key": "sender_role", "label": "Your Role", "default": "Founder, InizioWeb", "placeholder": "Founder, InizioWeb" },
      { "key": "cta_link", "label": "CTA Link", "default": "https://inizioweb.co.uk", "placeholder": "https://inizioweb.co.uk" },
      { "key": "cta_label", "label": "Button Label", "default": "See a live mockup", "placeholder": "See a live mockup" },
      { "key": "footer", "label": "Footer Text", "default": "InizioWeb · Premium hospitality web design · United Kingdom", "placeholder": "InizioWeb · United Kingdom" }
    ],
    "html": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0;padding:0;background:#0b0b0d;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;\"><tr><td align=\"center\" style=\"padding:32px 16px;\"><table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"width:100%;max-width:560px;background:#121216;border:1px solid rgba(255,255,255,0.08);border-radius:16px;overflow:hidden;color:#ffffff;\"><tr><td style=\"padding:46px 30px 16px;text-align:center;background:radial-gradient(circle at top,rgba(255,255,255,0.08),transparent);\"><div style=\"font-size:15px;letter-spacing:4px;text-transform:uppercase;color:#ffffff;\">{{logo}}</div><div style=\"font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:#d9b88a;margin-top:10px;\">{{eyebrow}}</div></td></tr><tr><td style=\"padding:34px 42px 10px;\"><h1 style=\"font-size:24px;line-height:1.35;font-weight:600;margin:0 0 22px;color:#ffffff;\">Hi {{recipient_name}}{{headline_suffix}}</h1><p style=\"font-size:15px;line-height:1.8;color:#b6b6bd;margin:0 0 20px;\">{{message}}</p><p style=\"font-size:15px;line-height:1.8;color:#b6b6bd;margin:0 0 26px;\">{{message2}}</p></td></tr><tr><td style=\"padding:0 42px 30px;\"><div style=\"border-top:1px solid rgba(255,255,255,0.08);border-bottom:1px solid rgba(255,255,255,0.08);padding:18px 0;text-align:center;font-size:12px;letter-spacing:0.4px;color:#8a8a92;\">{{highlights}}</div></td></tr><tr><td style=\"padding:0 42px 6px;text-align:center;\"><a href=\"{{cta_link}}\" style=\"display:inline-block;padding:15px 34px;border-radius:10px;background:linear-gradient(135deg,#ffffff,#cfcfcf);color:#0b0b0d;text-decoration:none;font-weight:600;font-size:14px;\">{{cta_label}}</a></td></tr><tr><td style=\"padding:34px 42px 40px;\"><p style=\"font-size:14px;line-height:1.5;color:#e8e8ea;margin:0;\">{{sender_name}}<br><span style=\"color:#77777f;font-size:13px;\">{{sender_role}}</span></p></td></tr><tr><td style=\"text-align:center;padding:20px;font-size:11px;color:#ffffff;opacity:0.4;border-top:1px solid rgba(255,255,255,0.06);\">{{footer}}</td></tr></table></td></tr></table>"
  },
  {
