yle=\"height:1px;background:rgba(255,255,255,0.08);margin:20px 0;\"></div><div style=\"text-align:center;padding:30px;\"><p style=\"opacity:0.7;font-size:13px;margin-bottom:15px;\">{{cta_text}}</p><a href=\"{{cta_link}}\" style=\"display:inline-block;padding:12px 22px;border-radius:10px;background:linear-gradient(135deg,#ffffff,#cfcfcf);color:#0b0b0d;text-decoration:none;font-weight:600;font-size:13px;\">{{cta_label}}</a></div><div style=\"text-align:center;padding:20px;font-size:11px;opacity:0.5;\">{{footer}}</div></td></tr></table></td></tr></table>"
