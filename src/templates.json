ing:13px 0;font-size:14px;color:#fff;text-align:right;\">{{due_date}}</td></tr></table></td></tr><tr><td style=\"padding:22px 42px 6px;text-align:center;\"><a href=\"{{cta_link}}\" style=\"display:inline-block;padding:15px 34px;border-radius:10px;background:linear-gradient(135deg,#ffffff,#cfcfcf);color:#0b0b0d;text-decoration:none;font-weight:600;font-size:14px;\">{{cta_label}}</a></td></tr><tr><td style=\"padding:26px 42px 40px;text-align:center;\"><p style=\"font-size:13px;line-height:1.6;color:#77777f;margin:0;\">Thank you — I appreciate your business.</p></td></tr><tr><td style=\"text-align:center;padding:20px;font-size:11px;color:#ffffff;opacity:0.4;border-top:1px solid rgba(255,255,255,0.06);\">{{footer}}</td></tr></table></td></tr></table>"
