    "html": "<div style=\"margin:0;padding:0;background:#0b0b0d;\"><div style=\"font-family:'Helvetica Neue',Arial,sans-serif;max-width:560px;margin:0 auto;background:#111114;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:44px 40px;color:#e8e8ea;\"><p style=\"font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#77777f;margin:0 0 10px;\">Proposal</p><h1 style=\"font-size:26px;font-weight:600;margin:0 0 18px;color:#fff;\">Hello {{recipient_name}}</h1><p style=\"font-size:15px;line-height:1.7;color:#b6b6bd;margin:0 0 16px;\">I noticed {{company}} and had a few thoughts.</p><p style=\"font-size:15px;line-height:1.7;color:#b6b6bd;margin:0 0 20px;\">{{message}}</p><div style=\"background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:18px 20px;margin:0 0 28px;\"><p style=\"font-size:12px;letter-spacing:1px;text-transform:uppercase;color:#77777f;margin:0 0 8px;\">What I'd build</p><p style=\"font-size:14px;line-height:1.6;color:#cfcfd6;margin:0;\">{{project_description}}</p></div><a href=\"{{cta_link}}\" style=\"display:inline-block;background:linear-gradient(135deg,#ffffff,#d8d8e0);color:#0b0b0d;text-decoration:none;font-weight:600;font-size:14px;padding:13px 22px;border-radius:12px;\">View Full Proposal</a></div></div>"
